#!/usr/bin/env bash
# football-wire CLI wrapper
# Handles PYTHONPATH. Activates container venv if present.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Container environment: activate mounted venv if available
# Host: system Python has everything, no venv needed
if [[ -f "/opt/ws-venvs/ml/bin/activate" ]]; then
    source /opt/ws-venvs/ml/bin/activate
fi

export PYTHONPATH="$SCRIPT_DIR/src${PYTHONPATH:+:$PYTHONPATH}"

exec python -m fbw "$@"
